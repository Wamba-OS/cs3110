# Production environment variables
ADMIN_PASSWORD=your-admin-password-here
AUTHOR_PASSWORD=your-author-password-here
JWT_SECRET=your-jwt-secret-here
DATABASE_URL=postgresql://user:password@host/database?sslmode=require

# Test environment variables (optional - for running tests)
# Create a separate test database on Neon to avoid polluting production data
TEST_DATABASE_URL=postgresql://user:password@host/test_database?sslmode=require
TEST_JWT_SECRET=test-jwt-secret
TEST_ADMIN_PASSWORD=test-admin-password
TEST_AUTHOR_PASSWORD=test-author-password
TEST_PORT=3001
